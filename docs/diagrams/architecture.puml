@startuml
!theme plain
skinparam shadowing false
skinparam packageStyle rectangle

package "Interface (HTTP)" {
  [App / Wiring]
  [Health + JWKS]
  [v1 Auth Router]
  [v1 Admin Router]
}

package "Application" {
  [Identity Context]
  [Session Context]
  [Access Context]
  [Ports + UnitOfWork]
}

package "Domain" {
  [identity]
  [session]
  [access]
}

package "Infrastructure" {
  [db.repositories + db.uow]
  [security.adapters]
  [clients.geo]
}

[App / Wiring] --> [v1 Auth Router]
[App / Wiring] --> [v1 Admin Router]
[App / Wiring] --> [Health + JWKS]

[v1 Auth Router] --> [Identity Context]
[v1 Auth Router] --> [Session Context]
[v1 Admin Router] --> [Access Context]
[v1 Admin Router] --> [Session Context]

[Identity Context] --> [identity]
[Session Context] --> [session]
[Access Context] --> [access]

[Identity Context] --> [Ports + UnitOfWork]
[Session Context] --> [Ports + UnitOfWork]
[Access Context] --> [Ports + UnitOfWork]

[db.repositories + db.uow] ..> [Ports + UnitOfWork]
[security.adapters] ..> [Ports + UnitOfWork]
[clients.geo] ..> [Ports + UnitOfWork]
@enduml
