# Common
APP_ENV=dev
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
DATABASE_URL=
AUTO_MIGRATE_ON_START=true
MIGRATION_MAX_RETRIES=20
MIGRATION_RETRY_DELAY=2

# Auth settings
AUTH_HASH_SECRET=change-me
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PHONE=

# JWT
JWT_ISSUER=
JWT_AUDIENCE=
JWT_ALGORITHMS=RS256
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

# Rate limit
AUTH_RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_LOGIN_MAX=20
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REFRESH_MAX=40
AUTH_RATE_LIMIT_REFRESH_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_REGISTER_MAX=20
AUTH_RATE_LIMIT_REGISTER_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_ADMIN_MAX=120
AUTH_RATE_LIMIT_ADMIN_WINDOW_SECONDS=60

# RFC 7807 problem type base URL
PROBLEM_TYPE_BASE_URL=https://example.com/problems
